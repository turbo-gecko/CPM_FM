# --- RomWBW hard-disk media (single slice) -----------------------------------

# RomWBW 8MB Hard Disk (1024 directory entry format). Pure filesystem image, no
# MBR prefix — matches a standalone hd1k_*.img (8,388,608 bytes).
diskdef wbw_hd1k
  seclen 512
  tracks 1024
  sectrk 16
  blocksize 4096
  maxdir 1024
  skew 0
  boottrk 2
  os 2.2
end

# RomWBW 8320KB Hard Disk Slice (512 directory entry format). Legacy format —
# matches a standalone hd512_*.img (8,519,680 bytes).
diskdef wbw_hd512
  seclen 512
  tracks 1040
  sectrk 16
  blocksize 4096
  maxdir 512
  skew 0
  boottrk 16
  os 2.2
end

# --- RC2014 (Grant Searle) hard-disk slice -----------------------------------

# RC2014 standard (Grant Searle) hard-disk slice 0 (8 MB). A CF card is a
# concatenation of these slices; cpm-fm opens slice 0 in Phase 1.
diskdef rc2014
  seclen 512
  tracks 512
  sectrk 32
  blocksize 4096
  maxdir 512
  skew 0
  boottrk 1
  os 2.2
end

