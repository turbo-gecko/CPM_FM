# Auto detect text files and perform LF normalization
* text=auto

# Source code — always LF in repo
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Shell scripts — LF in repo (bash/sh always expect LF)
*.sh text eol=lf
Makefile text eol=lf

# Windows batch/cmd files — CRLF in repo (Windows expects CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries — no conversion
*.pyc binary
*.pyo binary
*.egg-info/ binary
*.so binary
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
*.zip binary
